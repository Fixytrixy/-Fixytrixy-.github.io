/* ============================================================
   DESIGN SYSTEM – FIXAOTRIXA
   Dark, editorial, confident. Like a luxury organiser brand.
   ============================================================ */
:root {
  --bg: #0E0E0E;
  --bg2: #161616;
  --bg3: #1E1E1E;
  --bg4: #252525;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
  --text: #F0EDE8;
  --text2: rgba(240,237,232,0.55);
  --text3: rgba(240,237,232,0.3);
  --orange: #FF6B35;
  --orange2: #FF8C5A;
  --orange-glow: rgba(255,107,53,0.15);
  --green: #2ECC71;
  --teal: #1A7A6B;
  --teal2: #22A08A;
  --teal-bg: rgba(26,122,107,0.12);
  --red: #FF4444;
  --radius: 16px;
  --radius-sm: 10px;
  --radius-lg: 24px;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; font-size:16px; }

body {
  font-family: 'Syne', sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ============================================================
   SCROLL ANIMATIONS
   ============================================================ */
.sa { /* scroll-animate base */
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1),
              transform 0.7s cubic-bezier(0.16,1,0.3,1);
}
.sa.from-left { transform: translateX(-50px); }
.sa.from-right { transform: translateX(50px); }
.sa.scale-in { transform: scale(0.92) translateY(20px); }
.sa.visible {
  opacity: 1 !important;
  transform: none !important;
}
/* Stagger delays */
.sa-d1 { transition-delay: 0.1s; }
.sa-d2 { transition-delay: 0.2s; }
.sa-d3 { transition-delay: 0.3s; }
.sa-d4 { transition-delay: 0.4s; }
.sa-d5 { transition-delay: 0.5s; }
.sa-d6 { transition-delay: 0.6s; }

/* Number count-up animation */
.count-num {
  display: inline-block;
  transition: all 0.1s;
}

/* Text reveal – word by word */
.word-reveal .word {
  display: inline-block;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.word-reveal.visible .word {
  opacity: 1;
  transform: none;
}

/* ============================================================
   ANNOUNCEMENT BAR
   ============================================================ */
.ann {
  background: var(--orange);
  color: white;
  text-align: center;
  padding: 10px 16px;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.3px;
  position: relative;
  overflow: hidden;
}
.ann::before {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
  animation: shimmer 3s infinite;
}
@keyframes shimmer { to { left: 150%; } }
.ann a { color: white; text-decoration: underline; margin-left: 6px; }

/* ============================================================
   HEADER / NAV
   ============================================================ */
header {
  position: sticky; top: 0; z-index: 200;
  background: rgba(14,14,14,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0 32px;
  transition: box-shadow 0.3s;
}
header.scrolled { box-shadow: 0 4px 32px rgba(0,0,0,0.4); }
.nav {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  height: 66px;
}
.logo {
  font-family: 'Instrument Serif', serif;
  font-size: 26px;
  color: var(--text);
  text-decoration: none;
  display: flex; align-items: center; gap: 10px;
}
.logo-icon {
  width: 36px; height: 36px;
  background: var(--orange);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  box-shadow: 0 0 20px var(--orange-glow);
  transition: transform 0.3s, box-shadow 0.3s;
}
.logo:hover .logo-icon {
  transform: rotate(-8deg) scale(1.1);
  box-shadow: 0 0 30px rgba(255,107,53,0.4);
}
.logo-word { letter-spacing: -0.5px; }
.logo-word .o { color: var(--orange); }
.nav-links {
  display: flex; gap: 4px; list-style: none;
}
.nav-links a {
  text-decoration: none; color: var(--text2);
  font-size: 14px; font-weight: 600;
  padding: 8px 14px; border-radius: 8px;
  transition: color 0.2s, background 0.2s;
}
.nav-links a:hover { color: var(--text); background: var(--bg3); }
.nav-links a.sale { color: var(--orange); }
.nav-right { display: flex; align-items: center; gap: 8px; }
.nav-icon {
  width: 38px; height: 38px; border-radius: 10px;
  background: var(--bg3); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.nav-icon:hover { background: var(--bg4); transform: scale(1.08); }
.cart-btn {
  background: var(--text); color: var(--bg);
  border: none; padding: 10px 18px; border-radius: 10px;
  font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700;
  cursor: pointer; display: flex; align-items: center; gap: 6px;
  transition: all 0.2s;
}
.cart-btn:hover { background: var(--orange); color: white; transform: scale(1.03); }

/* ============================================================
   HERO
   ============================================================ */
.hero {
  min-height: 90vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  padding: 100px 24px 80px;
  position: relative;
  overflow: hidden;
}
/* Animated background grid */
.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: gridDrift 20s linear infinite;
  pointer-events: none;
}
@keyframes gridDrift { from{transform:translate(0,0)} to{transform:translate(60px,60px)} }
/* Radial glow */
.hero-glow {
  position: absolute;
  width: 700px; height: 700px;
  background: radial-gradient(circle at 50% 120%, var(--orange-glow) 0%, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  animation: glowPulse 4s ease-in-out infinite;
}
@keyframes glowPulse {
  0%,100% { transform: translate(-50%,-50%) scale(1); opacity:0.7; }
  50% { transform: translate(-50%,-50%) scale(1.15); opacity:1; }
}
.hero-chip {
  display: inline-flex; align-items: center; gap: 8px;
  border: 1px solid var(--border2);
  background: var(--bg2);
  color: var(--text2);
  font-size: 12px; font-weight: 600; letter-spacing: 2px;
  text-transform: uppercase;
  padding: 7px 16px; border-radius: 100px;
  margin-bottom: 32px;
  position: relative; z-index: 1;
  animation: fadeDown 0.6s ease both;
}
.hero-chip .dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--orange);
  animation: blink 2s infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
@keyframes fadeDown { from{opacity:0;transform:translateY(-16px)} to{opacity:1;transform:none} }

.hero h1 {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(48px, 7vw, 88px);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -2px;
  position: relative; z-index: 1;
  margin-bottom: 24px;
  animation: heroTitle 0.9s cubic-bezier(0.16,1,0.3,1) 0.1s both;
}
@keyframes heroTitle {
  from { opacity:0; transform: translateY(30px); }
  to { opacity:1; transform: none; }
}
.hero h1 em { font-style: italic; color: var(--orange); }
.hero h1 .line2 { display: block; }
.hero-sub {
  font-size: clamp(15px, 2vw, 18px);
  color: var(--text2);
  max-width: 520px;
  line-height: 1.75;
  margin-bottom: 40px;
  position: relative; z-index: 1;
  animation: heroTitle 0.9s cubic-bezier(0.16,1,0.3,1) 0.25s both;
}
.hero-btns {
  display: flex; gap: 12px; flex-wrap: wrap;
  justify-content: center;
  position: relative; z-index: 1;
  animation: heroTitle 0.9s cubic-bezier(0.16,1,0.3,1) 0.4s both;
}
.btn-primary {
  background: var(--orange); color: white;
  text-decoration: none; padding: 15px 30px; border-radius: 12px;
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 15px;
  display: inline-flex; align-items: center; gap: 8px;
  transition: all 0.25s; border: none; cursor: pointer;
  box-shadow: 0 4px 24px rgba(255,107,53,0.3);
}
.btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 36px rgba(255,107,53,0.45);
}
.btn-outline {
  background: transparent; color: var(--text);
  text-decoration: none; padding: 15px 30px; border-radius: 12px;
  font-family: 'Syne', sans-serif; font-weight: 600; font-size: 15px;
  display: inline-flex; align-items: center; gap: 8px;
  transition: all 0.25s;
  border: 1px solid var(--border2);
}
.btn-outline:hover { background: var(--bg3); border-color: var(--border); transform: translateY(-2px); }

/* Hero stats */
.hero-stats {
  display: flex; gap: 48px; justify-content: center;
  margin-top: 64px; flex-wrap: wrap;
  position: relative; z-index: 1;
  animation: heroTitle 0.9s cubic-bezier(0.16,1,0.3,1) 0.55s both;
}
.stat { text-align: center; }
.stat .n {
  font-family: 'Instrument Serif', serif;
  font-size: 36px;
  color: var(--text);
  line-height: 1;
  margin-bottom: 4px;
}
.stat .n span { color: var(--orange); }
.stat .l { font-size: 12px; color: var(--text3); font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }
.stat-div { width: 1px; background: var(--border); align-self: stretch; }

/* Scroll indicator */
.scroll-hint {
  position: absolute; bottom: 32px; left: 50%;
  transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  color: var(--text3); font-size: 11px; letter-spacing: 1.5px;
  text-transform: uppercase; font-weight: 600;
  animation: heroTitle 1s 1s both;
}
.scroll-dot {
  width: 24px; height: 38px; border-radius: 12px;
  border: 1px solid var(--border2);
  position: relative; display: flex; justify-content: center; padding-top: 6px;
}
.scroll-dot::after {
  content: '';
  width: 4px; height: 8px; border-radius: 2px;
  background: var(--orange);
  animation: scrollDown 2s infinite;
}
@keyframes scrollDown {
  0% { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(16px); opacity: 0; }
}

/* ============================================================
   TRUST BAR
   ============================================================ */
.trust-bar {
  background: var(--bg2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 16px 24px;
  overflow: hidden;
}
.trust-track {
  display: flex; gap: 56px; align-items: center;
  animation: scroll-trust 25s linear infinite;
  white-space: nowrap;
}
@keyframes scroll-trust {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.trust-item {
  display: flex; align-items: center; gap: 10px;
  font-size: 13px; font-weight: 600; color: var(--text2);
  flex-shrink: 0;
}
.trust-item .ic { font-size: 18px; }

/* ============================================================
   SECTIONS SHARED
   ============================================================ */
section { padding: 96px 24px; }
.inner { max-width: 1200px; margin: 0 auto; }
.sec-label {
  font-size: 11px; font-weight: 700;
  letter-spacing: 3px; text-transform: uppercase;
  color: var(--orange); margin-bottom: 12px;
}
.sec-title {
  font-family: 'Instrument Serif', serif;
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 400; line-height: 1.1;
  letter-spacing: -1px;
}
.sec-sub {
  font-size: 16px; color: var(--text2);
  line-height: 1.75; margin-top: 12px;
  max-width: 520px;
}

/* ============================================================
   ROOM GRID
   ============================================================ */
.rooms-section { background: var(--bg); padding: 96px 24px; }
.rooms-head {
  display: flex; align-items: flex-end; justify-content: space-between;
  margin-bottom: 48px; flex-wrap: wrap; gap: 24px;
}
.rooms-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}
.room-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px 24px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all 0.35s cubic-bezier(0.16,1,0.3,1);
  text-decoration: none; display: block;
  group: true;
}
.room-card::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(circle at 50% 120%, var(--orange-glow) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.4s;
}
.room-card:hover { border-color: rgba(255,107,53,0.3); transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.3); }
.room-card:hover::before { opacity: 1; }
.room-card:hover .room-arrow { transform: translateX(4px); opacity: 1; }
.room-emoji { font-size: 36px; margin-bottom: 16px; display: block; }
.room-name { font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.room-count { font-size: 13px; color: var(--text3); font-weight: 500; }
.room-arrow {
  position: absolute; top: 24px; right: 24px;
  font-size: 18px; color: var(--orange);
  opacity: 0; transition: all 0.3s;
}

/* ============================================================
   SIZE FILTER SECTION
   ============================================================ */
.size-section { background: var(--bg2); padding: 96px 24px; }
.size-tabs {
  display: flex; gap: 4px;
  background: var(--bg3); border-radius: 14px; padding: 4px;
  width: fit-content; margin: 32px 0;
  border: 1px solid var(--border);
}
.size-tab {
  padding: 10px 24px; border-radius: 10px;
  font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;
  cursor: pointer; border: none; background: transparent;
  color: var(--text2); transition: all 0.25s;
}
.size-tab.active { background: var(--text); color: var(--bg); }
.size-products {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px;
  max-width: 600px;
}
.size-product {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 20px;
  display: flex; align-items: center; gap: 16px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
}
.size-product:hover { border-color: var(--border2); transform: translateX(4px); background: var(--bg4); }
.size-product .sp-icon { font-size: 36px; flex-shrink: 0; }
.sp-name { font-size: 15px; font-weight: 700; color: var(--text); }
.sp-price { font-size: 14px; color: var(--orange); font-weight: 600; margin-top: 2px; }
.size-layout {
  display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start;
}
.size-info-text {
  padding-top: 80px;
}
.size-info-text p {
  font-size: 16px; color: var(--text2); line-height: 1.8; margin-bottom: 20px;
}
.size-info-text strong { color: var(--text); }

/* ============================================================
   BEFORE / AFTER
   ============================================================ */
.ba-section { background: var(--bg); padding: 96px 24px; }
.ba-cards {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  margin-top: 48px;
}
.ba-card {
  border-radius: var(--radius-lg);
  padding: 44px;
  position: relative; overflow: hidden;
}
.ba-card.before {
  background: var(--bg2);
  border: 1px solid var(--border);
}
.ba-card.after {
  background: linear-gradient(135deg, #0D2E27 0%, #1A4A3E 100%);
  border: 1px solid rgba(34,160,138,0.25);
}
.ba-pill {
  display: inline-block;
  font-size: 11px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; padding: 6px 14px; border-radius: 100px;
  margin-bottom: 24px;
}
.ba-card.before .ba-pill { background: var(--bg3); color: var(--text3); }
.ba-card.after .ba-pill { background: rgba(34,160,138,0.25); color: var(--teal2); }
.ba-title {
  font-family: 'Instrument Serif', serif;
  font-size: 36px; font-weight: 400;
  margin-bottom: 20px; line-height: 1.2;
}
.ba-card.after .ba-title { color: white; }
.ba-items { list-style: none; display: flex; flex-direction: column; gap: 12px; }
.ba-items li {
  display: flex; align-items: flex-start; gap: 12px;
  font-size: 15px; line-height: 1.5;
}
.ba-card.before .ba-items li { color: var(--text2); }
.ba-card.after .ba-items li { color: rgba(255,255,255,0.8); }
.ba-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
.ba-bg-text {
  position: absolute; bottom: -20px; right: -10px;
  font-family: 'Instrument Serif', serif;
  font-size: 120px; font-weight: 400;
  opacity: 0.04; pointer-events: none;
  line-height: 1;
}
.ba-card.after .ba-bg-text { opacity: 0.06; }

/* ============================================================
   QUIZ SECTION
   ============================================================ */
.quiz-section { background: var(--bg2); padding: 96px 24px; }
.quiz-card {
  background: linear-gradient(135deg, #0D2E27, #1A4A3E);
  border: 1px solid rgba(34,160,138,0.2);
  border-radius: var(--radius-lg);
  padding: 64px;
  text-align: center;
  position: relative; overflow: hidden;
  max-width: 700px; margin: 0 auto;
}
.quiz-card::before {
  content: '';
  position: absolute; top: -100px; left: 50%;
  transform: translateX(-50%);
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(34,160,138,0.1) 0%, transparent 70%);
  pointer-events: none;
}
.quiz-card h2 {
  font-family: 'Instrument Serif', serif;
  font-size: 38px; color: white;
  margin-bottom: 16px; line-height: 1.2;
  position: relative; z-index: 1;
}
.quiz-card p {
  font-size: 16px; color: rgba(255,255,255,0.6);
  line-height: 1.75; margin-bottom: 36px;
  position: relative; z-index: 1;
}
.btn-teal {
  background: var(--teal2); color: white;
  text-decoration: none; padding: 15px 32px;
  border-radius: 12px; font-family: 'Syne', sans-serif;
  font-weight: 700; font-size: 15px;
  display: inline-flex; align-items: center; gap: 8px;
  transition: all 0.25s; border: none; cursor: pointer;
  position: relative; z-index: 1;
  box-shadow: 0 4px 24px rgba(34,160,138,0.3);
}
.btn-teal:hover { transform: translateY(-3px); box-shadow: 0 8px 36px rgba(34,160,138,0.4); }

/* ============================================================
   USP / WHY US
   ============================================================ */
.usp-section { background: var(--bg); padding: 96px 24px; }
.usp-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  margin-top: 48px;
}
.usp-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 32px;
  transition: all 0.35s cubic-bezier(0.16,1,0.3,1);
  position: relative; overflow: hidden;
}
.usp-card::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 2px; background: var(--orange);
  transform: scaleX(0); transition: transform 0.3s;
}
.usp-card:hover { border-color: var(--border2); transform: translateY(-4px); }
.usp-card:hover::after { transform: scaleX(1); }
.usp-icon { font-size: 32px; margin-bottom: 18px; }
.usp-card h4 {
  font-size: 17px; font-weight: 700;
  margin-bottom: 10px; color: var(--text);
}
.usp-card p { font-size: 14px; color: var(--text2); line-height: 1.75; }

/* ============================================================
   REVIEWS
   ============================================================ */
.reviews-section { background: var(--bg2); padding: 96px 24px; }
.reviews-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  margin-top: 48px;
}
.review {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: var(--radius); padding: 28px;
  transition: transform 0.3s;
}
.review:hover { transform: translateY(-3px); }
.rev-stars { font-size: 14px; color: #F4A821; letter-spacing: 2px; margin-bottom: 14px; }
.rev-text { font-family: 'Instrument Serif', serif; font-size: 17px; color: var(--text); line-height: 1.6; margin-bottom: 20px; font-style: italic; }
.rev-author { display: flex; align-items: center; gap: 10px; }
.rev-av {
  width: 38px; height: 38px; border-radius: 50%;
  background: var(--orange); display: flex; align-items: center; justify-content: center;
  font-family: 'Instrument Serif', serif; font-weight: 400; color: white; font-size: 16px;
}
.rev-name { font-size: 13px; font-weight: 700; color: var(--text); }
.rev-loc { font-size: 12px; color: var(--text3); margin-top: 1px; }

/* ============================================================
   SEO TEXT SECTION (hidden but indexed by Google)
   ============================================================ */
.seo-section {
  background: var(--bg);
  padding: 80px 24px;
  border-top: 1px solid var(--border);
}
.seo-inner { max-width: 900px; margin: 0 auto; }
.seo-inner h2 {
  font-family: 'Instrument Serif', serif;
  font-size: 32px; font-weight: 400; margin-bottom: 20px;
  letter-spacing: -0.5px;
}
.seo-inner h3 {
  font-family: 'Instrument Serif', serif;
  font-size: 22px; font-weight: 400;
  margin: 32px 0 12px; color: var(--text);
}
.seo-inner p {
  font-size: 15px; color: var(--text2);
  line-height: 1.9; margin-bottom: 14px;
}
.seo-tags {
  display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px;
}
.seo-tag {
  text-decoration: none; color: var(--text2);
  background: var(--bg2); border: 1px solid var(--border);
  padding: 7px 14px; border-radius: 100px;
  font-size: 13px; font-weight: 600; transition: all 0.2s;
}
.seo-tag:hover { color: var(--orange); border-color: rgba(255,107,53,0.3); }

/* ============================================================
   NEWSLETTER
   ============================================================ */
.nl-section {
  background: var(--bg2);
  padding: 80px 24px;
  border-top: 1px solid var(--border);
  text-align: center;
}
.nl-inner { max-width: 520px; margin: 0 auto; }
.nl-inner h2 {
  font-family: 'Instrument Serif', serif;
  font-size: 40px; font-weight: 400;
  letter-spacing: -1px; margin-bottom: 12px;
}
.nl-inner p { font-size: 15px; color: var(--text2); margin-bottom: 28px; line-height: 1.7; }
.nl-form { display: flex; gap: 8px; }
.nl-form input {
  flex: 1; background: var(--bg3); border: 1px solid var(--border2);
  border-radius: 10px; padding: 14px 18px;
  font-family: 'Syne', sans-serif; font-size: 14px;
  color: var(--text); outline: none;
  transition: border-color 0.2s;
}
.nl-form input:focus { border-color: var(--orange); }
.nl-form input::placeholder { color: var(--text3); }
.nl-form button {
  background: var(--orange); color: white; border: none;
  padding: 14px 22px; border-radius: 10px;
  font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;
  cursor: pointer; white-space: nowrap; transition: all 0.2s;
}
.nl-form button:hover { transform: scale(1.04); box-shadow: 0 4px 20px rgba(255,107,53,0.4); }
.nl-note { font-size: 12px; color: var(--text3); margin-top: 12px; }

/* ============================================================
   FOOTER
   ============================================================ */
footer {
  background: var(--bg);
  padding: 64px 24px 28px;
  border-top: 1px solid var(--border);
}
.footer-grid {
  max-width: 1200px; margin: 0 auto;
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px;
  padding-bottom: 48px;
  border-bottom: 1px solid var(--border);
}
.footer-brand .logo { margin-bottom: 16px; }
.footer-desc { font-size: 14px; color: var(--text3); line-height: 1.75; margin-bottom: 24px; max-width: 260px; }
.pay-badges { display: flex; gap: 8px; flex-wrap: wrap; }
.pay-b {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 6px; padding: 5px 10px;
  font-size: 11px; font-weight: 700; color: var(--text3);
}
.fc h5 {
  font-size: 10px; font-weight: 700; letter-spacing: 2.5px;
  text-transform: uppercase; color: var(--orange);
  margin-bottom: 20px;
}
.fc ul { list-style: none; }
.fc li { margin-bottom: 11px; }
.fc a {
  text-decoration: none; color: var(--text3);
  font-size: 14px; transition: color 0.2s;
}
.fc a:hover { color: var(--text); }
.footer-bottom {
  max-width: 1200px; margin: 24px auto 0;
  display: flex; justify-content: space-between; align-items: center;
  font-size: 12px; color: var(--text3); flex-wrap: wrap; gap: 10px;
}
.socials { display: flex; gap: 14px; }
.socials a { color: var(--text3); text-decoration: none; font-size: 13px; transition: color 0.2s; }
.socials a:hover { color: var(--orange); }

/* ============================================================
   QUIZ MODAL
   ============================================================ */
.quiz-modal {
  display: none; position: fixed; inset: 0; z-index: 1000;
  background: rgba(0,0,0,0.85); backdrop-filter: blur(10px);
  align-items: center; justify-content: center; padding: 24px;
}
.quiz-modal.open { display: flex; }
.quiz-box {
  background: var(--bg2); border: 1px solid var(--border2);
  border-radius: var(--radius-lg); padding: 48px;
  max-width: 560px; width: 100%;
  animation: popIn 0.4s cubic-bezier(0.16,1,0.3,1);
}
@keyframes popIn { from{opacity:0;transform:scale(0.9)} to{opacity:1;transform:none} }
.quiz-step { display: none; }
.quiz-step.active { display: block; }
.quiz-q {
  font-family: 'Instrument Serif', serif;
  font-size: 28px; margin-bottom: 8px;
}
.quiz-hint { font-size: 14px; color: var(--text3); margin-bottom: 28px; }
.quiz-opts {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.quiz-opt {
  background: var(--bg3); border: 1.5px solid var(--border);
  border-radius: 12px; padding: 16px 14px;
  cursor: pointer; transition: all 0.2s;
  font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 600;
  text-align: left; display: flex; align-items: center; gap: 10px;
  color: var(--text);
}
.quiz-opt:hover { border-color: var(--orange); background: var(--bg4); }
.quiz-opt .qo-icon { font-size: 22px; flex-shrink: 0; }
.quiz-result {
  background: var(--bg3); border-radius: 14px; padding: 28px;
  border: 1px solid var(--border2);
}
.quiz-result h3 { font-family: 'Instrument Serif', serif; font-size: 24px; margin-bottom: 10px; }
.quiz-result p { font-size: 14px; color: var(--text2); line-height: 1.7; }
.quiz-close {
  position: absolute; top: 20px; right: 20px;
  width: 36px; height: 36px; border-radius: 8px;
  background: var(--bg3); border: 1px solid var(--border);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  font-size: 18px; color: var(--text2); transition: all 0.2s;
}
.quiz-close:hover { background: var(--bg4); color: var(--text); }
.quiz-progress {
  display: flex; gap: 6px; margin-bottom: 28px;
}
.qp-dot {
  flex: 1; height: 3px; border-radius: 2px;
  background: var(--bg3);
  transition: background 0.3s;
}
.qp-dot.done { background: var(--orange); }

/* ============================================================
   MOBILE
   ============================================================ */
@media(max-width: 768px) {
  .rooms-grid { grid-template-columns: repeat(2, 1fr); }
  .ba-cards, .size-layout { grid-template-columns: 1fr; }
  .usp-grid, .reviews-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .footer-brand { grid-column: 1/-1; }
  .nav-links { display: none; }
  .hero h1 { letter-spacing: -1px; }
  .hero-stats { gap: 28px; }
  .stat-div { display: none; }
  .quiz-opts { grid-template-columns: 1fr; }
  .quiz-card { padding: 40px 28px; }
  .nl-form { flex-direction: column; }
  .size-products { grid-template-columns: 1fr; }
  .ba-card { padding: 32px; }
}