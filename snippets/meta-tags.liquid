{% comment %}
  Meta Tags snippet – SEO meta tags rendered in <head>
{% endcomment %}

{%- assign og_title       = page_title -%}
{%- assign og_url         = canonical_url -%}
{%- assign og_type        = 'website' -%}
{%- assign og_description = page_description | default: shop.description | default: '' -%}
{%- assign og_image       = settings.logo | image_url: width: 1200 -%}

{%- if request.page_type == 'product' -%}
  {%- assign og_type        = 'product' -%}
  {%- assign og_description = product.description | strip_html | truncate: 160 -%}
  {%- if product.featured_image -%}
    {%- assign og_image = product.featured_image | image_url: width: 1200 -%}
  {%- endif -%}
{%- elsif request.page_type == 'collection' -%}
  {%- if collection.image -%}
    {%- assign og_image = collection.image | image_url: width: 1200 -%}
  {%- endif -%}
{%- elsif request.page_type == 'article' -%}
  {%- assign og_type = 'article' -%}
  {%- if article.image -%}
    {%- assign og_image = article.image | image_url: width: 1200 -%}
  {%- endif -%}
{%- endif -%}

<!-- Open Graph -->
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
{%- if og_description != blank -%}
  <meta property="og:description" content="{{ og_description | strip_html | escape }}">
{%- endif -%}
{%- if og_image != blank -%}
  <meta property="og:image" content="https:{{ og_image }}">
  <meta property="og:image:width" content="1200">
{%- endif -%}
<meta property="og:locale" content="sv_SE">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
{%- if og_description != blank -%}
  <meta name="twitter:description" content="{{ og_description | strip_html | truncate: 200 | escape }}">
{%- endif -%}
{%- if og_image != blank -%}
  <meta name="twitter:image" content="https:{{ og_image }}">
{%- endif -%}

<!-- Product-specific meta -->
{%- if request.page_type == 'product' -%}
  <meta property="product:price:amount" content="{{ product.price | divided_by: 100.0 }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}
