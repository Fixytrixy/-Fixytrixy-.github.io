<article class="product-card">
  <a href="{{ product.url }}">
    <img src="{{ product.featured_image | image_url: width: 400, height: 300, crop: 'center' }}" alt="{{ product.title }}" width="400" height="300" loading="lazy">
  </a>
  <h4><a href="{{ product.url }}">{{ product.title }}</a></h4>
  <div class="product-rating">
    {% assign stars = product.metafields.global.rating | default: 4.5 %}
    {% assign stars_floor = stars | floor %}
    <div class="stars">
      {% for i in (1..5) %}
        {% if i <= stars_floor %}
          <span class="star filled">★</span>
        {% else %}
          <span class="star">☆</span>
        {% endif %}
      {% endfor %}
    </div>
    <span class="rating-number">({{ stars }})</span>
  </div>
  <span class="price">{{ product.price | money }}</span>
  <a href="{{ product.url }}" class="buy-btn">Se produkt</a>
</article>
