<section class="testimonials-section">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header sa">
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        {% render 'testimonial-card',
          author: block.settings.author,
          location: block.settings.location,
          rating: block.settings.rating,
          text: block.settings.text,
          avatar: block.settings.avatar
        %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kundrecensioner",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Rubrik",
      "default": "Vad våra kunder säger"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underrubrik",
      "default": "Tusentals nöjda svenska hem"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Recension",
      "settings": [
        {
          "type": "text",
          "id": "author",
          "label": "Namn",
          "default": "Anna Svensson"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Ort",
          "default": "Stockholm"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Betyg",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Recensionstext",
          "default": "Fantastiska produkter! Mitt kök är äntligen organiserat och det känns så skönt."
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Profilbild (valfritt)"
        }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Kundrecensioner",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
