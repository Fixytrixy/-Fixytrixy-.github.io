{% comment %}
  Hero Banner Section – Fixaotrixa Startsida
  Visar ett kraftfullt hero med före/efter-bilder och CTA
{% endcomment %}

<section class="hero-banner {% if section.settings.full_width %}hero-banner--full{% endif %}"
  style="min-height: {{ section.settings.min_height }}px;">
  <div class="hero-banner__media">
    {%- if section.settings.image != blank -%}
      <img
        srcset="{{ section.settings.image | image_url: width: 750 }} 750w,
                {{ section.settings.image | image_url: width: 1100 }} 1100w,
                {{ section.settings.image | image_url: width: 1500 }} 1500w,
                {{ section.settings.image | image_url: width: 2200 }} 2200w"
        src="{{ section.settings.image | image_url: width: 1500 }}"
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape }}"
        loading="eager"
        fetchpriority="high"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        class="hero-banner__img">
    {%- else -%}
      <div class="hero-banner__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-banner__placeholder-svg' }}
      </div>
    {%- endif -%}
    <div class="hero-banner__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  </div>

  <div class="hero-banner__content page-width">
    <div class="hero-banner__text {% if section.settings.text_alignment == 'center' %}hero-banner__text--center{% elsif section.settings.text_alignment == 'right' %}hero-banner__text--right{% endif %}">

      {%- if section.settings.subheading != blank -%}
        <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero-banner__heading h0">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="hero-banner__description rte">{{ section.settings.description }}</div>
      {%- endif -%}

      <!-- Trust signals -->
      <div class="hero-banner__trust">
        <div class="hero-banner__stars" aria-label="4,8 av 5 stjärnor">
          {% for i in (1..5) %}
            <svg class="star{% if i == 5 %} star--half{% endif %}" aria-hidden="true" width="20" height="20" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
          <span>4,8/5 ({{ section.settings.review_count }} recensioner)</span>
        </div>
        <span class="hero-banner__customers">{{ section.settings.customer_count }}+ nöjda kunder</span>
      </div>

      <div class="hero-banner__ctas">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--large">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="btn btn--secondary btn--large">
            {{ section.settings.button_label_2 }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <!-- Before/After Teaser -->
    {%- if section.settings.show_before_after -%}
    <div class="hero-banner__before-after" aria-label="Före och efter-bilder">
      <div class="before-after">
        <div class="before-after__item before-after__item--before">
          <span class="before-after__label">Före</span>
          {%- if section.settings.before_image != blank -%}
            <img src="{{ section.settings.before_image | image_url: width: 400 }}"
              alt="Rörigt hem – innan organisering"
              loading="lazy" width="400" height="300">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'before-after__placeholder' }}
          {%- endif -%}
        </div>
        <div class="before-after__divider" aria-hidden="true">→</div>
        <div class="before-after__item before-after__item--after">
          <span class="before-after__label before-after__label--after">Efter</span>
          {%- if section.settings.after_image != blank -%}
            <img src="{{ section.settings.after_image | image_url: width: 400 }}"
              alt="Organiserat hem – efter Fixaotrixa"
              loading="lazy" width="400" height="300">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'before-after__placeholder' }}
          {%- endif -%}
        </div>
      </div>
    </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bakgrundsbild"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay-opacitet",
      "default": 40
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "label": "Minsta höjd",
      "default": 600
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Underrubrik",
      "default": "Sveriges bästa förvaringslösningar"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Rubrik",
      "default": "Förvandla ditt hem från rörigt till organiserat"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Beskrivning",
      "default": "<p>Hitta smarta förvaringslösningar för kök, sovrum, badrum och mer. Gratis frakt över 499 kr.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Textjustering",
      "options": [
        {"value": "left", "label": "Vänster"},
        {"value": "center", "label": "Centrerad"},
        {"value": "right", "label": "Höger"}
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Knapp 1 – text",
      "default": "Shoppa nu"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Knapp 1 – länk"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Knapp 2 – text",
      "default": "Ta quizet"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Knapp 2 – länk"
    },
    {
      "type": "number",
      "id": "review_count",
      "label": "Antal recensioner",
      "default": 1247
    },
    {
      "type": "number",
      "id": "customer_count",
      "label": "Antal kunder",
      "default": 8500
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full bredd",
      "default": true
    },
    {
      "type": "header",
      "content": "Före/Efter-bilder"
    },
    {
      "type": "checkbox",
      "id": "show_before_after",
      "label": "Visa före/efter-bilder",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Före-bild"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "Efter-bild"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
