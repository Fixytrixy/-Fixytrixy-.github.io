{% comment %}
  Did You Know Section – fakta och infografik om förvaring
{% endcomment %}

<section class="did-you-know section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="did-you-know__header">
      <h2 class="did-you-know__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="did-you-know__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'fact' -%}
          <div class="fact-card" {{ block.shopify_attributes }}>
            <div class="fact-card__icon" aria-hidden="true">{{ block.settings.emoji }}</div>
            <div class="fact-card__stat">{{ block.settings.stat }}</div>
            <h3 class="fact-card__title">{{ block.settings.title }}</h3>
            <p class="fact-card__description">{{ block.settings.description }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Visste du att...",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Sektionsrubrik",
      "default": "Visste du att..."
    }
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Faktaruta",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji",
          "default": "📊"
        },
        {
          "type": "text",
          "id": "stat",
          "label": "Statistik / siffra",
          "default": "67%"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Rubrik",
          "default": "Känner sig mer stressade"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Beskrivning",
          "default": "av personer med rörigt hem upplever ökad stress och ångest."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Visste du att...",
      "blocks": [
        {
          "type": "fact",
          "settings": {
            "emoji": "😰",
            "stat": "67%",
            "title": "Känner sig stressade",
            "description": "av personer med rörigt hem upplever ökad stress och ångest dagligen."
          }
        },
        {
          "type": "fact",
          "settings": {
            "emoji": "⏰",
            "stat": "55 min",
            "title": "Tid slösad per dag",
            "description": "lägger en genomsnittlig person på att leta efter borttappade föremål varje dag."
          }
        },
        {
          "type": "fact",
          "settings": {
            "emoji": "💰",
            "stat": "4 200 kr",
            "title": "Köpt dubbelt",
            "description": "köper en genomsnittlig svensk familj om per år av föremål de redan har men inte hittar."
          }
        },
        {
          "type": "fact",
          "settings": {
            "emoji": "😊",
            "stat": "89%",
            "title": "Mår bättre",
            "description": "av våra kunder rapporterar att de känner sig mer avslappnade och produktiva efter organisering."
          }
        }
      ]
    }
  ]
}
{% endschema %}
