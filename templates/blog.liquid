<div class="blog-page">
  <div class="container">
    <div class="blog-header">
      <h1>{{ blog.title }}</h1>
      <p>{{ blog.description }}</p>
    </div>

    <div class="blog-content">
      <main class="blog-articles">
        {%- paginate blog.articles by 12 -%}
          {%- for article in blog.articles -%}
            <article class="blog-post">
              {%- if article.image -%}
                <div class="post-image">
                  <a href="{{ article.url }}">
                    <img src="{{ article.image | image_url: width: 600, height: 400, crop: 'center' }}" alt="{{ article.title }}" width="600" height="400">
                  </a>
                </div>
              {%- endif -%}

              <div class="post-content">
                <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>

                <div class="post-meta">
                  <span class="post-date">{{ article.published_at | date: '%d %B %Y' }}</span>
                  {%- if article.author -%}
                    <span class="post-author">av {{ article.author }}</span>
                  {%- endif -%}
                  <span class="post-comments">{{ article.comments_count }} kommentarer</span>
                </div>

                <div class="post-excerpt">
                  {{ article.excerpt_or_content | strip_html | truncate: 200 }}
                </div>

                <a href="{{ article.url }}" class="read-more">Läs mer</a>
              </div>
            </article>
          {%- endfor -%}
        {%- endpaginate -%}
      </main>

      <aside class="blog-sidebar">
        <div class="sidebar-widget">
          <h3>Sök artiklar</h3>
          <form action="{{ routes.search_url }}" method="get" class="blog-search">
            <input type="search" name="q" placeholder="Sök i bloggen..." required>
            <input type="hidden" name="type" value="article">
            <button type="submit">Sök</button>
          </form>
        </div>

        <div class="sidebar-widget">
          <h3>Populära ämnen</h3>
          <div class="topic-tags">
            <a href="/blogs/news/tagged/kök" class="topic-tag">Kök</a>
            <a href="/blogs/news/tagged/sovrum" class="topic-tag">Sovrum</a>
            <a href="/blogs/news/tagged/badrum" class="topic-tag">Badrum</a>
            <a href="/blogs/news/tagged/trädgård" class="topic-tag">Trädgård</a>
            <a href="/blogs/news/tagged/organisering" class="topic-tag">Organisering</a>
            <a href="/blogs/news/tagged/förvaring" class="topic-tag">Förvaring</a>
          </div>
        </div>

        <div class="sidebar-widget">
          <h3>Senaste artiklar</h3>
          <div class="recent-posts">
            {%- for article in blog.articles limit: 5 -%}
              <div class="recent-post">
                {%- if article.image -%}
                  <img src="{{ article.image | image_url: width: 80, height: 80, crop: 'center' }}" alt="{{ article.title }}" width="80" height="80">
                {%- endif -%}
                <div class="recent-post-content">
                  <h4><a href="{{ article.url }}">{{ article.title }}</a></h4>
                  <span class="recent-post-date">{{ article.published_at | date: '%d %b' }}</span>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="sidebar-widget">
          <h3>Prenumerera</h3>
          <p>Få våra senaste tips om förvaring direkt i din inbox.</p>
          {% form 'customer', id: 'blog-newsletter' %}
            <input type="email" name="contact[email]" placeholder="Din e-postadress" required>
            <button type="submit">Prenumerera</button>
          {% endform %}
        </div>
      </aside>
    </div>
  </div>
</div>

<style>
.blog-page {
  padding: 2rem 0;
}

.blog-header {
  text-align: center;
  margin-bottom: 3rem;
}

.blog-header h1 {
  font-size: 2.5rem;
  margin-bottom: 1rem;
  color: #333;
}

.blog-header p {
  font-size: 1.1rem;
  color: #666;
  max-width: 600px;
  margin: 0 auto;
}

.blog-content {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: 3rem;
}

.blog-articles {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 2rem;
}

.blog-post {
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  transition: transform 0.3s ease;
}

.blog-post:hover {
  transform: translateY(-5px);
}

.post-image img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.post-content {
  padding: 2rem;
}

.post-content h2 {
  margin-bottom: 1rem;
}

.post-content h2 a {
  text-decoration: none;
  color: #333;
  font-size: 1.3rem;
  transition: color 0.3s;
}

.post-content h2 a:hover {
  color: {{ settings.color_primary }};
}

.post-meta {
  display: flex;
  gap: 1rem;
  font-size: 0.9rem;
  color: #999;
  margin-bottom: 1rem;
}

.post-excerpt {
  color: #666;
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

.read-more {
  display: inline-block;
  color: {{ settings.color_primary }};
  text-decoration: none;
  font-weight: bold;
  transition: color 0.3s;
}

.read-more:hover {
  color: #45a049;
}

.blog-sidebar {
  background: white;
  padding: 2rem;
  border-radius: 12px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  height: fit-content;
  position: sticky;
  top: 2rem;
}

.sidebar-widget {
  margin-bottom: 2rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid #eee;
}

.sidebar-widget:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.sidebar-widget h3 {
  margin-bottom: 1rem;
  color: #333;
}

.blog-search {
  display: flex;
  gap: 0.5rem;
}

.blog-search input {
  flex: 1;
  padding: 0.75rem;
  border: 1px solid #ddd;
  border-radius: 4px;
}

.blog-search button {
  padding: 0.75rem 1rem;
  background-color: {{ settings.color_primary }};
  color: white;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: background-color 0.3s;
}

.blog-search button:hover {
  background-color: #45a049;
}

.topic-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.topic-tag {
  display: inline-block;
  padding: 0.5rem 1rem;
  background-color: #f0f0f0;
  color: #333;
  text-decoration: none;
  border-radius: 20px;
  font-size: 0.9rem;
  transition: all 0.3s;
}

.topic-tag:hover {
  background-color: {{ settings.color_primary }};
  color: white;
}

.recent-posts {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.recent-post {
  display: flex;
  gap: 1rem;
  align-items: center;
}

.recent-post img {
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: 4px;
}

.recent-post-content h4 {
  margin-bottom: 0.25rem;
  font-size: 0.9rem;
}

.recent-post-content h4 a {
  text-decoration: none;
  color: #333;
  transition: color 0.3s;
}

.recent-post-content h4 a:hover {
  color: {{ settings.color_primary }};
}

.recent-post-date {
  font-size: 0.8rem;
  color: #999;
}

@media (max-width: 768px) {
  .blog-content {
    grid-template-columns: 1fr;
  }

  .blog-articles {
    grid-template-columns: 1fr;
  }

  .blog-sidebar {
    order: 2;
  }
}
</style>