{% comment %}
  Page Compare Template – Fixaotrixa
  Renders the product comparison section for the /pages/jamfor-produkter page.
  Create a Shopify page with template "page.compare" to use this template.
{% endcomment %}

<div class="page-compare">
  <!-- Breadcrumbs -->
  <nav class="breadcrumbs page-width" aria-label="Brödsmulor">
    <ol class="breadcrumbs__list">
      <li class="breadcrumbs__item">
        <a href="/" class="breadcrumbs__link">Hem</a>
      </li>
      <li class="breadcrumbs__item breadcrumbs__item--current" aria-current="page">
        {{ page.title }}
      </li>
    </ol>
  </nav>

  {% section 'product-compare' %}
</div>
