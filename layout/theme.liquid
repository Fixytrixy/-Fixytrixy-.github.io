<!DOCTYPE html>
<html lang="{{ shop.locale }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">

  <title>
    {{ page_title }}
    {%- if current_tags -%}
      – tagged "{{ current_tags | join: ', ' }}"
    {%- endif -%}
    {%- if current_page != 1 -%}
      – Page {{ current_page }}
    {%- endif -%}
    {%- unless page_title contains shop.name -%}
      – {{ shop.name }}
    {%- endunless -%}
  </title>

  {% assign seo_description = page_description | default: collection.description | default: shop.meta_description | default: shop.description %}
  <meta name="description" content="{{ seo_description | escape }}">
  <meta name="robots" content="index, follow">

  <link rel="canonical" href="{{ canonical_url }}">

  {% assign seo_image = page_image %}
  {% if seo_image == blank and product != blank %}{% assign seo_image = product.featured_image %}{% endif %}
  {% if seo_image == blank and article != blank %}{% assign seo_image = article.image %}{% endif %}
  {% if seo_image == blank and collection != blank %}{% assign seo_image = collection.image %}{% endif %}
  {% if seo_image == blank and settings.logo != blank %}{% assign seo_image = settings.logo %}{% endif %}
  {% if seo_image == blank and shop.logo != blank %}{% assign seo_image = shop.logo %}{% endif %}

  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:description" content="{{ seo_description | escape }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name | escape }}">
  <meta property="og:type" content="{% if template contains 'product' %}product{% elsif template contains 'article' %}article{% else %}website{% endif %}">
  <meta property="og:locale" content="sv_SE">
  {% if seo_image != blank %}
    <meta property="og:image" content="{{ seo_image | image_url: width: 1200 }}">
    <meta property="og:image:alt" content="{{ page_title | escape }}">
    <meta name="twitter:image" content="{{ seo_image | image_url: width: 1200 }}">
  {% endif %}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  <meta name="twitter:description" content="{{ seo_description | escape }}">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "{{ shop.name | escape }}",
        "url": "{{ shop.url }}"{% if seo_image != blank %}, "logo": "{{ seo_image | image_url: width: 600 }}"{% endif %},
        "sameAs": []
      },
      {
        "@type": "WebSite",
        "url": "{{ shop.url }}",
        "name": "{{ shop.name | escape }}",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ shop.url }}/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    ]
  }
  </script>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32, crop: 'center' }}">
  {%- endif -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</head>

<body class="template-{{ template | replace: '.', '-' | handle }}">
  <a class="skip-to-content-link visually-hidden" href="#main">Skip to content</a>

  <div class="ann">Fri frakt över 499 kr • Klarna & Swish • 30 dagars öppet köp</div>

  {%- assign main_menu_links = linklists['main-menu'].links -%}
  {%- assign fallback_menu = 'Kök|/collections/kok,Sovrum|/collections/sovrum,Badrum|/collections/badrum,Vardagsrum|/collections/vardagsrum,Trädgård|/collections/tradgard,Kontor|/collections/kontor,Om oss|/pages/om-oss' | split: ',' -%}

  <header role="banner">
    <div class="nav container">
      <div class="logo">
        <a href="{{ routes.root_url }}" title="{{ shop.name }}">
          <span class="logo-word">{{ shop.name }}</span>
        </a>
      </div>

      <button class="menu-toggle" aria-controls="mobile-menu" aria-expanded="false" aria-label="Öppna meny">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <nav class="desktop-nav" role="navigation" aria-label="Huvudmeny">
        <ul class="nav-links">
          {%- if main_menu_links != blank -%}
            {%- for link in main_menu_links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            {%- for item in fallback_menu -%}
              {%- assign item_parts = item | split: '|' -%}
              <li><a href="{{ item_parts[1] }}">{{ item_parts[0] }}</a></li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </nav>

      <div class="header-actions">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input type="search" name="q" placeholder="Sök produkter..." value="{{ search.terms | escape }}">
          <button type="submit">Sök</button>
        </form>
        <a href="{{ routes.cart_url }}" class="cart-link">Kundvagn ({{ cart.item_count }})</a>
      </div>
    </div>

    <nav id="mobile-menu" class="mobile-nav" aria-hidden="true">
      <ul class="nav-links">
        {%- if main_menu_links != blank -%}
          {%- for link in main_menu_links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          {%- for item in fallback_menu -%}
            {%- assign item_parts = item | split: '|' -%}
            <li><a href="{{ item_parts[1] }}">{{ item_parts[0] }}</a></li>
          {%- endfor -%}
        {%- endif -%}
      </ul>
    </nav>
  </header>

  <main id="main" role="main">
    {{ content_for_layout }}
  </main>

  <footer role="contentinfo">
    <div class="container">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Smart förvaring för svenska hem.</p>
      <nav>
        <a href="{{ pages['om-oss'].url | default: '/pages/om-oss' }}">Om oss</a>
        <a href="{{ pages['kontakt'].url | default: '/pages/kontakt' }}">Kontakt</a>
        <a href="{{ pages['leveransinformation'].url | default: '/pages/leveransinformation' }}">Leveransinformation</a>
        <a href="{{ pages['returpolicy'].url | default: '/pages/returpolicy' }}">Returpolicy</a>
        <a href="{{ pages['integritetspolicy'].url | default: '/pages/integritetspolicy' }}">Integritetspolicy</a>
      </nav>
    </div>
  </footer>

  {%- if settings.enable_newsletter -%}
    <div class="newsletter-popup" id="newsletter-popup">
      <div class="popup-content">
        <h3>Prenumerera på vårt nyhetsbrev</h3>
        <p>Få de senaste erbjudandena och tips om förvaring.</p>
        {% form 'customer', id: 'newsletter-form' %}
          <input type="email" name="contact[email]" placeholder="Din e-postadress" required>
          <button type="submit">Prenumerera</button>
        {% endform %}
        <button class="close-popup">&times;</button>
      </div>
    </div>
  {%- endif -%}
</body>
</html>