# Shopify Store
SHOPIFY_STORE_URL=xivfqd-hz.myshopify.com
SHOPIFY_ACCESS_TOKEN=din_shopify_access_token_här

# Amazon Product Advertising API
AMAZON_ACCESS_KEY=din_amazon_access_key_här
AMAZON_SECRET_KEY=din_amazon_secret_key_här
AMAZON_PARTNER_TAG=fixaotrixa-21
AMAZON_REGION=eu-west-1
AMAZON_MARKETPLACE=www.amazon.se

# Google Analytics 4
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel
META_PIXEL_ID=XXXXXXXXXXXXXXXXX

# TikTok Pixel
TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXX

# Klaviyo
KLAVIYO_API_KEY=din_klaviyo_api_nyckel_här
KLAVIYO_LIST_ID=din_klaviyo_list_id_här

# Google Merchant Center
GOOGLE_MERCHANT_CENTER_ID=XXXXXXXXX
